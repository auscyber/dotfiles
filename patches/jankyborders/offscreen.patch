diff --git a/src/misc/screen.h b/src/misc/screen.h
new file mode 100644
index 0000000000..4e73fd67f2
--- /dev/null
+++ b/src/misc/screen.h
@@ -0,0 +1,7 @@
+#pragma once
+#include <CoreGraphics/CoreGraphics.h>
+
+// Returns true when less than half of the window's area overlaps the visible
+// desktop (the union of all active displays). Window managers that emulate
+// virtual workspaces hide windows by shoving them (almost) entirely offscreen.
+extern bool screen_window_mostly_offscreen(CGRect window_frame);
diff --git a/src/misc/screen.m b/src/misc/screen.m
new file mode 100644
index 0000000000..43cd8988e5
--- /dev/null
+++ b/src/misc/screen.m
@@ -0,0 +1,39 @@
+#include "screen.h"
+
+// Fraction of a window's area that must overlap the visible desktop for the
+// window to be considered onscreen. Below this it is treated as hidden.
+#define SCREEN_MIN_VISIBLE_FRACTION 0.5f
+
+// Union of all active display bounds, in CoreGraphics global coordinates
+// (top-left origin) -- the same coordinate space as SLSGetWindowBounds.
+static CGRect screen_total_bounds(void) {
+  uint32_t count = 0;
+  if (CGGetActiveDisplayList(0, NULL, &count) != kCGErrorSuccess || count == 0)
+    return CGRectNull;
+
+  CGDirectDisplayID displays[count];
+  if (CGGetActiveDisplayList(count, displays, &count) != kCGErrorSuccess)
+    return CGRectNull;
+
+  CGRect total = CGRectNull;
+  for (uint32_t i = 0; i < count; i++)
+    total = CGRectUnion(total, CGDisplayBounds(displays[i]));
+
+  return total;
+}
+
+bool screen_window_mostly_offscreen(CGRect window_frame) {
+  float window_area = window_frame.size.width * window_frame.size.height;
+  if (window_area <= 0.f)
+    return false;
+
+  CGRect total = screen_total_bounds();
+  if (CGRectIsNull(total))
+    return false;
+
+  CGRect visible = CGRectIntersection(window_frame, total);
+  float visible_area =
+      CGRectIsNull(visible) ? 0.f : visible.size.width * visible.size.height;
+
+  return (visible_area / window_area) < SCREEN_MIN_VISIBLE_FRACTION;
+}
