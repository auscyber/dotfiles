diff --git a/src/source_pid.h b/src/source_pid.h
new file mode 100644
index 0000000..a746901
--- /dev/null
+++ b/src/source_pid.h
@@ -0,0 +1,61 @@
+#pragma once
+#include <ApplicationServices/ApplicationServices.h>
+#include <CoreFoundation/CoreFoundation.h>
+#include <stdbool.h>
+
+// In macOS 26 (Tahoe), menu bar item windows are owned by Control Center
+// instead of their source applications. This module provides functions to
+// find the actual source PID using the Accessibility API.
+
+// Check if we're running on macOS 26 or later where this workaround is needed
+bool source_pid_needs_workaround(void);
+
+// Get the source PID for a menu bar item window by matching its bounds
+// to accessibility elements in running applications' extras menu bars.
+// Returns 0 if the source PID cannot be determined.
+pid_t source_pid_for_window(CGRect window_bounds);
+
+// Get the source application name for a menu bar item window.
+// Returns NULL if not found. Caller must free the returned string.
+char *source_name_for_window(CGRect window_bounds);
+
+// Resolve source pid and source app name in a single lookup pass.
+// Returns 0 if not found. Caller must free out_name when non-NULL.
+pid_t source_pid_for_window_with_name(CGRect window_bounds, char **out_name);
+
+// Resolve source pid and source app name using optional menu item name hint.
+// Returns 0 if not found. Caller must free out_name when non-NULL.
+pid_t source_pid_for_window_with_name_hint(CGRect window_bounds,
+                                           const char *item_name,
+                                           char **out_name);
+
+// Derive the menu bar window bounds for a specific running application pid and
+// item name directly from its AX extras menu bar.
+bool source_window_bounds_for_pid(pid_t pid,
+                                  const char *name,
+                                  CGRect *out_bounds);
+
+// Initialize the source PID cache (call once at startup)
+void source_pid_cache_init(void);
+
+// Refresh the cached running applications list
+void source_pid_cache_refresh(void);
+
+// Request required permissions (Accessibility + Screen Recording)
+// for Tahoe workaround flows. Returns true when Accessibility is trusted.
+bool source_pid_request_permissions(void);
+
+// Menu item descriptor for enumeration
+typedef struct
+{
+    char *owner; // Application name (caller must free)
+    char *name;  // Menu item title (caller must free)
+    pid_t pid;   // Application process ID
+    float x_pos; // X position on menu bar (for sorting)
+} source_menu_item_t;
+
+// Enumerate all menu bar items across all running applications.
+// Returns dynamically allocated array of menu items; caller must free each item's
+// owner/name strings, and free the array itself.
+// Returns NULL if items is NULL or on error.
+int source_pid_enumerate_menu_items(source_menu_item_t **out_items);
diff --git a/src/source_pid.m b/src/source_pid.m
new file mode 100644
index 0000000..37ed36c
--- /dev/null
+++ b/src/source_pid.m
@@ -0,0 +1,739 @@
+#include "source_pid.h"
+#include "misc/helpers.h"
+#include <AppKit/AppKit.h>
+#include <libproc.h>
+#include <pthread.h>
+#include <math.h>
+
+// The Accessibility API attribute for the extras menu bar (status items area)
+// This is documented in Apple's Accessibility Programming Guide
+#define kAXExtrasMenuBarAttribute CFSTR("AXExtrasMenuBar")
+
+// Older SDKs may not expose this symbol even though AX supports it at runtime.
+#ifndef kAXFrameAttribute
+#define kAXFrameAttribute CFSTR("AXFrame")
+#endif
+
+// Cache for running applications and their extras menu bars
+typedef struct {
+    pid_t pid;
+    char* name;
+    AXUIElementRef app_element;
+    AXUIElementRef extras_menu_bar;
+    bool has_extras_menu_bar;
+} cached_app_t;
+
+// Fast lookup cache: maps window bounds to (pid, app_name, menu_item_name)
+typedef struct {
+    CGRect bounds;
+    pid_t pid;
+    char* app_name;      // pointing to cached_app_t->name, do NOT free
+    char* menu_item_name; // owned by this cache entry, must free
+} bounds_cache_entry_t;
+
+static cached_app_t* g_cached_apps = NULL;
+static int g_cached_apps_count = 0;
+static bounds_cache_entry_t* g_bounds_cache = NULL;
+static int g_bounds_cache_count = 0;
+static uint64_t g_bounds_cache_refresh_time = 0;
+static pthread_mutex_t g_cache_mutex = PTHREAD_MUTEX_INITIALIZER;
+static bool g_initialized = false;
+static uint64_t g_last_refresh_time = 0;
+static const uint64_t CACHE_REFRESH_INTERVAL_NS = 5000000000ULL; // 5 seconds in nanoseconds
+
+static void free_bounds_cache(void) {
+    if (!g_bounds_cache) {
+        g_bounds_cache_count = 0;
+        g_bounds_cache_refresh_time = 0;
+        return;
+    }
+
+    for (int i = 0; i < g_bounds_cache_count; i++) {
+        if (g_bounds_cache[i].menu_item_name) {
+            free(g_bounds_cache[i].menu_item_name);
+        }
+    }
+
+    free(g_bounds_cache);
+    g_bounds_cache = NULL;
+    g_bounds_cache_count = 0;
+    g_bounds_cache_refresh_time = 0;
+}
+
+// Helper to calculate distance between two points
+static double point_distance(CGPoint a, CGPoint b) {
+    double dx = a.x - b.x;
+    double dy = a.y - b.y;
+    return sqrt(dx * dx + dy * dy);
+}
+
+// Helper to get the center of a rect
+static CGPoint rect_center(CGRect rect) {
+    return CGPointMake(rect.origin.x + rect.size.width / 2.0,
+                       rect.origin.y + rect.size.height / 2.0);
+}
+
+static char *copy_process_name_for_pid(pid_t pid)
+{
+    if (pid <= 0)
+    {
+        return NULL;
+    }
+
+    NSRunningApplication *app = [NSRunningApplication runningApplicationWithProcessIdentifier:pid];
+    if (app.localizedName)
+    {
+        return strdup([app.localizedName UTF8String]);
+    }
+
+    char buffer[PROC_PIDPATHINFO_MAXSIZE] = "";
+    if (proc_name(pid, buffer, sizeof(buffer)) > 0)
+    {
+        return strdup(buffer);
+    }
+
+    return NULL;
+}
+
+bool source_pid_needs_workaround(void) {
+    // macOS Tahoe (26.x) changed menu bar item ownership to Control Center
+    // Check at runtime using NSProcessInfo
+    NSOperatingSystemVersion version = [[NSProcessInfo processInfo] operatingSystemVersion];
+    // macOS Tahoe is version 26.x
+    return version.majorVersion >= 26;
+}
+
+bool source_pid_request_permissions(void) {
+    if (!source_pid_needs_workaround()) {
+        return true;
+    }
+
+#if __MAC_OS_X_VERSION_MAX_ALLOWED >= 110000
+    if (__builtin_available(macOS 11.0, *)) {
+        // Trigger Screen Recording prompt when needed.
+        CGRequestScreenCaptureAccess();
+    }
+#endif
+
+    // Trigger Accessibility prompt when needed.
+    const void* keys[] = { kAXTrustedCheckOptionPrompt };
+    const void* values[] = { kCFBooleanTrue };
+    CFDictionaryRef options = CFDictionaryCreate(kCFAllocatorDefault,
+                                                 keys,
+                                                 values,
+                                                 1,
+                                                 &kCFCopyStringDictionaryKeyCallBacks,
+                                                 &kCFTypeDictionaryValueCallBacks);
+
+    bool trusted = AXIsProcessTrustedWithOptions(options);
+    CFRelease(options);
+    return trusted;
+}
+
+void source_pid_cache_init(void) {
+    if (g_initialized) return;
+    g_initialized = true;
+    source_pid_cache_refresh();
+}
+
+static void free_cached_app(cached_app_t* app) {
+    if (app->name) {
+        free(app->name);
+        app->name = NULL;
+    }
+    if (app->extras_menu_bar) {
+        CFRelease(app->extras_menu_bar);
+        app->extras_menu_bar = NULL;
+    }
+    if (app->app_element) {
+        CFRelease(app->app_element);
+        app->app_element = NULL;
+    }
+}
+
+void source_pid_cache_refresh(void) {
+    // Throttle refreshes to avoid performance issues
+    uint64_t now = clock_gettime_nsec_np(CLOCK_MONOTONIC);
+
+    pthread_mutex_lock(&g_cache_mutex);
+
+    // Check throttle inside the lock to avoid race conditions
+    if (g_last_refresh_time > 0 && (now - g_last_refresh_time) < CACHE_REFRESH_INTERVAL_NS) {
+        pthread_mutex_unlock(&g_cache_mutex);
+        return; // Skip refresh if we refreshed recently
+    }
+
+    g_last_refresh_time = now;
+
+    // Free existing cache
+    if (g_cached_apps) {
+        for (int i = 0; i < g_cached_apps_count; i++) {
+            free_cached_app(&g_cached_apps[i]);
+        }
+        free(g_cached_apps);
+        g_cached_apps = NULL;
+        g_cached_apps_count = 0;
+    }
+    free_bounds_cache();
+
+    // Get list of running applications
+    NSArray* running_apps = [[NSWorkspace sharedWorkspace] runningApplications];
+    g_cached_apps_count = (int)[running_apps count];
+    g_cached_apps = calloc(g_cached_apps_count, sizeof(cached_app_t));
+
+    int actual_count = 0;
+    for (NSRunningApplication* app in running_apps) {
+
+        pid_t pid = app.processIdentifier;
+
+        cached_app_t* cached = &g_cached_apps[actual_count];
+        cached->pid = pid;
+        cached->name = app.localizedName ? strdup([app.localizedName UTF8String]) : NULL;
+        cached->app_element = AXUIElementCreateApplication(pid);
+        cached->extras_menu_bar = NULL;
+        cached->has_extras_menu_bar = false;
+
+        actual_count++;
+    }
+    g_cached_apps_count = actual_count;
+
+    pthread_mutex_unlock(&g_cache_mutex);
+}
+
+// Try to get the extras menu bar for an application (lazy initialization)
+static AXUIElementRef get_extras_menu_bar(cached_app_t* app) {
+    if (app->extras_menu_bar) {
+        return app->extras_menu_bar;
+    }
+
+    if (app->has_extras_menu_bar == false && app->app_element == NULL) {
+        return NULL;
+    }
+
+    // Check if accessibility is trusted
+    if (!AXIsProcessTrusted()) {
+        return NULL;
+    }
+
+    // Try to get the extras menu bar attribute
+    AXUIElementRef extras_bar = NULL;
+    AXError error = AXUIElementCopyAttributeValue(app->app_element,
+                                                   kAXExtrasMenuBarAttribute,
+                                                   (CFTypeRef*)&extras_bar);
+
+    if (error == kAXErrorSuccess && extras_bar) {
+        app->extras_menu_bar = extras_bar;
+        app->has_extras_menu_bar = true;
+        return extras_bar;
+    }
+
+    // Mark that we've tried and failed
+    app->has_extras_menu_bar = false;
+    return NULL;
+}
+
+// Get the frame of an accessibility element
+static bool get_ax_frame(AXUIElementRef element, CGRect* out_frame) {
+    AXValueRef position_value = NULL;
+    AXValueRef size_value = NULL;
+    CGPoint position;
+    CGSize size;
+
+    AXError err = AXUIElementCopyAttributeValue(element, kAXPositionAttribute,
+                                                 (CFTypeRef*)&position_value);
+    if (err != kAXErrorSuccess || !position_value) {
+        return false;
+    }
+
+    err = AXUIElementCopyAttributeValue(element, kAXSizeAttribute,
+                                         (CFTypeRef*)&size_value);
+    if (err != kAXErrorSuccess || !size_value) {
+        CFRelease(position_value);
+        return false;
+    }
+
+    bool success = false;
+    if (AXValueGetValue(position_value, kAXValueCGPointType, &position) &&
+        AXValueGetValue(size_value, kAXValueCGSizeType, &size)) {
+        out_frame->origin = position;
+        out_frame->size = size;
+        success = true;
+    }
+
+    CFRelease(position_value);
+    CFRelease(size_value);
+    return success;
+}
+
+static bool get_ax_frame_with_fallback(AXUIElementRef element, CGRect* out_frame) {
+    if (!element || !out_frame) {
+        return false;
+    }
+
+    if (get_ax_frame(element, out_frame)) {
+        return true;
+    }
+
+    CFTypeRef frame_ref = NULL;
+    AXError err = AXUIElementCopyAttributeValue(element, kAXFrameAttribute, &frame_ref);
+    if (err == kAXErrorSuccess && frame_ref) {
+        if (CFGetTypeID(frame_ref) == AXValueGetTypeID()) {
+            if (AXValueGetValue((AXValueRef)frame_ref, kAXValueCGRectType, out_frame)) {
+                CFRelease(frame_ref);
+                return true;
+            }
+        }
+        CFRelease(frame_ref);
+    }
+
+    AXUIElementRef window_ref = NULL;
+    err = AXUIElementCopyAttributeValue(element, kAXWindowAttribute, (CFTypeRef *)&window_ref);
+    if (err == kAXErrorSuccess && window_ref) {
+        bool ok = get_ax_frame(window_ref, out_frame);
+        if (!ok) {
+            CFTypeRef win_frame_ref = NULL;
+            AXError win_err = AXUIElementCopyAttributeValue(window_ref, kAXFrameAttribute, &win_frame_ref);
+            if (win_err == kAXErrorSuccess && win_frame_ref) {
+                if (CFGetTypeID(win_frame_ref) == AXValueGetTypeID()) {
+                    ok = AXValueGetValue((AXValueRef)win_frame_ref, kAXValueCGRectType, out_frame);
+                }
+                CFRelease(win_frame_ref);
+            }
+        }
+        CFRelease(window_ref);
+        return ok;
+    }
+
+    return false;
+}
+
+// Check if an accessibility element is enabled
+static bool is_ax_element_enabled(AXUIElementRef element) {
+    CFBooleanRef enabled_ref = NULL;
+    AXError err = AXUIElementCopyAttributeValue(element, kAXEnabledAttribute,
+                                                 (CFTypeRef*)&enabled_ref);
+    if (err != kAXErrorSuccess || !enabled_ref) {
+        return false;
+    }
+
+    bool enabled = CFBooleanGetValue(enabled_ref);
+    CFRelease(enabled_ref);
+    return enabled;
+}
+
+// Get children of an accessibility element
+static CFArrayRef get_ax_children(AXUIElementRef element) {
+    CFArrayRef children = NULL;
+    AXUIElementCopyAttributeValue(element, kAXChildrenAttribute,
+                                   (CFTypeRef*)&children);
+    return children;
+}
+
+static CFArrayRef get_ax_visible_children(AXUIElementRef element) {
+    CFArrayRef children = NULL;
+    AXUIElementCopyAttributeValue(element, kAXVisibleChildrenAttribute,
+                                   (CFTypeRef*)&children);
+    return children;
+}
+
+static bool cfstring_equals_cstr(CFTypeRef value_ref, const char *expected)
+{
+    if (!value_ref || !expected)
+    {
+        return false;
+    }
+
+    if (CFGetTypeID(value_ref) != CFStringGetTypeID())
+    {
+        return false;
+    }
+
+    char buffer[256] = "";
+    if (!CFStringGetCString((CFStringRef)value_ref,
+                            buffer,
+                            sizeof(buffer),
+                            kCFStringEncodingUTF8))
+    {
+        return false;
+    }
+
+    return strcmp(buffer, expected) == 0;
+}
+
+static bool ax_element_matches_name(AXUIElementRef element, const char *expected)
+{
+    if (!element || !expected)
+    {
+        return false;
+    }
+
+    CFTypeRef title_ref = NULL;
+    CFTypeRef description_ref = NULL;
+    CFTypeRef identifier_ref = NULL;
+
+    AXUIElementCopyAttributeValue(element, kAXTitleAttribute, &title_ref);
+    AXUIElementCopyAttributeValue(element, kAXDescriptionAttribute, &description_ref);
+    AXUIElementCopyAttributeValue(element, kAXIdentifierAttribute, &identifier_ref);
+
+    bool matches = cfstring_equals_cstr(title_ref, expected) ||
+                   cfstring_equals_cstr(description_ref, expected) ||
+                   cfstring_equals_cstr(identifier_ref, expected);
+
+    if (title_ref)
+    {
+        CFRelease(title_ref);
+    }
+    if (description_ref)
+    {
+        CFRelease(description_ref);
+    }
+    if (identifier_ref)
+    {
+        CFRelease(identifier_ref);
+    }
+
+    return matches;
+}
+
+bool source_window_bounds_for_pid(pid_t pid, const char *name, CGRect *out_bounds)
+{
+    if (!source_pid_needs_workaround() || pid <= 0 || !name || !out_bounds)
+    {
+        return false;
+    }
+
+    if (!source_pid_request_permissions())
+    {
+        return false;
+    }
+
+    AXUIElementRef app = AXUIElementCreateApplication(pid);
+    if (!app)
+    {
+        return false;
+    }
+
+    CFTypeRef extras_ref = NULL;
+    AXError error = AXUIElementCopyAttributeValue(app,
+                                                  kAXExtrasMenuBarAttribute,
+                                                  &extras_ref);
+    if (error != kAXErrorSuccess || !extras_ref)
+    {
+        CFRelease(app);
+        return false;
+    }
+
+    CFArrayRef children = NULL;
+    error = AXUIElementCopyAttributeValue((AXUIElementRef)extras_ref,
+                                          kAXVisibleChildrenAttribute,
+                                          (CFTypeRef *)&children);
+    if (error != kAXErrorSuccess || !children)
+    {
+        CFRelease(extras_ref);
+        CFRelease(app);
+        return false;
+    }
+
+    bool found = false;
+    CFIndex child_count = CFArrayGetCount(children);
+    for (CFIndex i = 0; i < child_count; i++)
+    {
+        AXUIElementRef child = (AXUIElementRef)CFArrayGetValueAtIndex(children, i);
+        if (!child || !ax_element_matches_name(child, name))
+        {
+            continue;
+        }
+
+        CGRect child_frame;
+        if (get_ax_frame(child, &child_frame))
+        {
+            *out_bounds = child_frame;
+            found = true;
+            break;
+        }
+
+        AXUIElementRef window_ref = NULL;
+        error = AXUIElementCopyAttributeValue(child,
+                                              kAXWindowAttribute,
+                                              (CFTypeRef *)&window_ref);
+        if (error == kAXErrorSuccess && window_ref)
+        {
+            if (get_ax_frame(window_ref, &child_frame))
+            {
+                *out_bounds = child_frame;
+                found = true;
+                CFRelease(window_ref);
+                break;
+            }
+
+            CFRelease(window_ref);
+        }
+    }
+
+    CFRelease(children);
+    CFRelease(extras_ref);
+    CFRelease(app);
+    return found;
+}
+
+int source_pid_enumerate_menu_items(source_menu_item_t** out_items)
+{
+    if (!out_items)
+    {
+        return 0;
+    }
+
+    source_pid_cache_init();
+    source_pid_cache_refresh();
+
+    // Allocate temporary array to hold results
+    source_menu_item_t* items = calloc(256, sizeof(source_menu_item_t)); // Start with 256 slots
+    if (!items)
+    {
+        return 0;
+    }
+
+    int item_count = 0;
+    int max_items = 256;
+
+    pthread_mutex_lock(&g_cache_mutex);
+
+    // Iterate through all cached applications
+    for (int i = 0; i < g_cached_apps_count; i++)
+    {
+        cached_app_t* app = &g_cached_apps[i];
+
+        // Get this app's extras menu bar
+        AXUIElementRef extras_bar = get_extras_menu_bar(app);
+        if (!extras_bar)
+        {
+            continue;
+        }
+
+        CFArrayRef children = get_ax_children(extras_bar);
+        if (!children)
+        {
+            continue;
+        }
+
+        CFIndex child_count = CFArrayGetCount(children);
+        for (CFIndex j = 0; j < child_count; j++)
+        {
+            AXUIElementRef child = (AXUIElementRef)CFArrayGetValueAtIndex(children, j);
+            if (!child || !is_ax_element_enabled(child))
+            {
+                continue;
+            }
+
+            // Get the title/name of the menu item
+            CFStringRef title_ref = NULL;
+            AXError err = AXUIElementCopyAttributeValue(child, kAXTitleAttribute,
+                                                         (CFTypeRef*)&title_ref);
+            if (err != kAXErrorSuccess || !title_ref)
+            {
+                continue;
+            }
+
+            char* title = cfstring_copy(title_ref);
+            CFRelease(title_ref);
+
+            // Skip empty titles
+            if (!title || strlen(title) == 0)
+            {
+                if (title) free(title);
+                continue;
+            }
+
+            CGRect child_frame;
+            if (!get_ax_frame(child, &child_frame))
+            {
+                free(title);
+                continue;
+            }
+
+            // Reallocate if needed
+            if (item_count >= max_items)
+            {
+                max_items *= 2;
+                source_menu_item_t* new_items = realloc(items, max_items * sizeof(source_menu_item_t));
+                if (!new_items)
+                {
+                    free(title);
+                    CFRelease(children);
+                    break;
+                }
+                items = new_items;
+            }
+
+            // Fill in the item
+            items[item_count].owner = app->name ? strdup(app->name) : strdup("Unknown");
+            items[item_count].name = title;
+            items[item_count].pid = app->pid;
+            items[item_count].x_pos = child_frame.origin.x;
+            item_count++;
+        }
+
+        CFRelease(children);
+    }
+
+    pthread_mutex_unlock(&g_cache_mutex);
+
+    *out_items = items;
+    return item_count;
+}
+
+static void ensure_bounds_cache_locked(void) {
+    if (g_bounds_cache && g_bounds_cache_refresh_time == g_last_refresh_time) {
+        return;
+    }
+
+    free_bounds_cache();
+
+    int max_items = 256;
+    g_bounds_cache = calloc(max_items, sizeof(bounds_cache_entry_t));
+    if (!g_bounds_cache) {
+        return;
+    }
+
+    for (int i = 0; i < g_cached_apps_count; i++) {
+        cached_app_t* app = &g_cached_apps[i];
+
+        AXUIElementRef extras_bar = get_extras_menu_bar(app);
+        if (!extras_bar) {
+            continue;
+        }
+
+        CFArrayRef children = get_ax_visible_children(extras_bar);
+        if (!children) {
+            children = get_ax_children(extras_bar);
+        }
+        if (!children) {
+            continue;
+        }
+
+        CFIndex child_count = CFArrayGetCount(children);
+        for (CFIndex j = 0; j < child_count; j++) {
+            AXUIElementRef child = (AXUIElementRef)CFArrayGetValueAtIndex(children, j);
+            if (!child || !is_ax_element_enabled(child)) {
+                continue;
+            }
+
+            CGRect child_frame;
+            if (!get_ax_frame_with_fallback(child, &child_frame)) {
+                continue;
+            }
+
+            if (g_bounds_cache_count >= max_items) {
+                max_items *= 2;
+                bounds_cache_entry_t* new_cache = realloc(g_bounds_cache,
+                                                          max_items * sizeof(bounds_cache_entry_t));
+                if (!new_cache) {
+                    CFRelease(children);
+                    return;
+                }
+                g_bounds_cache = new_cache;
+            }
+
+            char* title = NULL;
+            CFTypeRef title_ref = NULL;
+            AXError err = AXUIElementCopyAttributeValue(child, kAXTitleAttribute, &title_ref);
+            if (err == kAXErrorSuccess && title_ref && CFGetTypeID(title_ref) == CFStringGetTypeID()) {
+                title = cfstring_copy((CFStringRef)title_ref);
+            }
+            if (title_ref) {
+                CFRelease(title_ref);
+            }
+
+            g_bounds_cache[g_bounds_cache_count].bounds = child_frame;
+            g_bounds_cache[g_bounds_cache_count].pid = app->pid;
+            g_bounds_cache[g_bounds_cache_count].app_name = app->name;
+            g_bounds_cache[g_bounds_cache_count].menu_item_name = title;
+            g_bounds_cache_count++;
+        }
+
+        CFRelease(children);
+    }
+
+    g_bounds_cache_refresh_time = g_last_refresh_time;
+}
+
+pid_t source_pid_for_window_with_name_hint(CGRect window_bounds,
+                                           const char *item_name,
+                                           char **out_name) {
+    if (!source_pid_needs_workaround()) {
+        if (out_name) *out_name = NULL;
+        return 0;
+    }
+
+    if (!source_pid_request_permissions()) {
+        if (out_name) *out_name = NULL;
+        return 0;
+    }
+
+    source_pid_cache_init();
+
+    pthread_mutex_lock(&g_cache_mutex);
+
+    ensure_bounds_cache_locked();
+
+    CGPoint window_center = rect_center(window_bounds);
+    pid_t result_pid = 0;
+    const char *result_app_name = NULL;
+    double best_distance = 1e9;
+
+    for (int pass = 0; pass < 2; pass++) {
+        for (int i = 0; i < g_bounds_cache_count; i++) {
+            bounds_cache_entry_t *entry = &g_bounds_cache[i];
+
+            if (pass == 0 && item_name) {
+                if (!entry->menu_item_name || strcmp(entry->menu_item_name, item_name) != 0) {
+                    continue;
+                }
+            }
+
+            CGPoint child_center = rect_center(entry->bounds);
+            double distance = point_distance(window_center, child_center);
+            double w_diff = fabs(entry->bounds.size.width - window_bounds.size.width);
+            double h_diff = fabs(entry->bounds.size.height - window_bounds.size.height);
+
+            if (distance <= 6.0 && w_diff <= 8.0 && h_diff <= 8.0 && distance < best_distance) {
+                result_pid = entry->pid;
+                result_app_name = entry->app_name;
+                best_distance = distance;
+            }
+            // Fallback for Tahoe menu extras where CG/AX size can drift.
+            else if (distance <= 14.0 && distance < best_distance) {
+                result_pid = entry->pid;
+                result_app_name = entry->app_name;
+                best_distance = distance;
+            }
+        }
+    }
+
+    if (out_name) {
+        *out_name = NULL;
+        if (result_app_name) {
+            *out_name = strdup(result_app_name);
+        }
+        if (!*out_name && result_pid > 0) {
+            *out_name = copy_process_name_for_pid(result_pid);
+        }
+    }
+
+    pthread_mutex_unlock(&g_cache_mutex);
+    return result_pid;
+}
+
+pid_t source_pid_for_window_with_name(CGRect window_bounds, char **out_name) {
+    return source_pid_for_window_with_name_hint(window_bounds, NULL, out_name);
+}
+
+pid_t source_pid_for_window(CGRect window_bounds) {
+    return source_pid_for_window_with_name_hint(window_bounds, NULL, NULL);
+}
+
+char* source_name_for_window(CGRect window_bounds) {
+    char *result = NULL;
+    source_pid_for_window_with_name_hint(window_bounds, NULL, &result);
+    return result;
+}
